---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { postSlug } from '../../utils/posts';
import { withBase } from '../../utils/path';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: postSlug(post.id) }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const formatter = new Intl.DateTimeFormat('zh-CN', { dateStyle: 'long' });
const wordCount = post.body?.length ?? post.data.description.length;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 520));
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section article-section">
    <div class="container article-layout">
      <aside class="article-rail" aria-label="文章信息">
        <a class="back-link" href={withBase('/blog/')}>返回文章</a>
        <dl>
          <div>
            <dt>Published</dt>
            <dd>{formatter.format(post.data.pubDate)}</dd>
          </div>
          <div>
            <dt>Reading</dt>
            <dd>{readingMinutes} min</dd>
          </div>
          <div>
            <dt>Topics</dt>
            <dd>{post.data.tags.join(' / ')}</dd>
          </div>
        </dl>
      </aside>

      <div class="article-main">
        <header>
          <p class="eyebrow">Technical Note</p>
          <h1>{post.data.title}</h1>
          <p>{post.data.description}</p>
          <ul class="chip-list">
            {post.data.tags.map((tag) => <li class="chip">{tag}</li>)}
          </ul>
        </header>

        <div class="article-content">
          <div class="prose">
            <Content />
          </div>
          {
            headings.length > 0 && (
              <nav class="toc" aria-label="文章目录">
                <span>On this page</span>
                {headings.filter((heading) => heading.depth <= 3).map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}
              </nav>
            )
          }
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-section {
    padding-block-start: 66px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 58px;
    align-items: start;
  }

  .article-rail {
    position: sticky;
    top: 92px;
    display: grid;
    gap: 24px;
  }

  .back-link {
    display: inline-flex;
    color: var(--muted);
    font-weight: 720;
  }

  .back-link:hover {
    color: var(--accent-strong);
  }

  dl {
    display: grid;
    gap: 0;
    margin: 0;
    border-top: 1px solid var(--line);
  }

  dl div {
    border-bottom: 1px solid var(--line);
    padding-block: 13px;
  }

  dt {
    color: var(--faint);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  dd {
    margin: 3px 0 0;
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 720;
    line-height: 1.5;
  }

  header {
    max-width: 860px;
    margin-bottom: 44px;
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 30px;
  }

  header h1 {
    max-width: 900px;
    margin: 0;
    color: var(--text);
    font-size: clamp(2.15rem, 5.6vw, 4.7rem);
    font-weight: 840;
    letter-spacing: 0;
    line-height: 1.05;
  }

  header p:not(.eyebrow) {
    max-width: 760px;
    color: var(--muted);
    font-size: 1.12rem;
  }

  .article-content {
    display: grid;
    grid-template-columns: minmax(0, 760px) minmax(180px, 240px);
    gap: 44px;
    align-items: start;
  }

  .toc {
    position: sticky;
    top: 92px;
    display: grid;
    gap: 8px;
    border-left: 1px solid var(--line);
    padding-left: 16px;
  }

  .toc span {
    color: var(--faint);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .toc a {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 680;
    line-height: 1.35;
  }

  .toc a:hover {
    color: var(--accent-strong);
  }

  .prose {
    max-width: none;
  }

  .prose :global(h2) {
    scroll-margin-top: 96px;
    border-top: 1px solid var(--line);
    padding-top: 28px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin-inline: 0;
    padding: 12px 0 12px 18px;
    color: var(--text);
    background: color-mix(in srgb, var(--accent-soft), transparent 62%);
  }

  @media (max-width: 1060px) {
    .article-layout,
    .article-content {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .article-rail,
    .toc {
      position: static;
    }

    .toc {
      order: -1;
      border-left: 0;
      border-block: 1px solid var(--line);
      padding: 14px 0;
    }
  }
</style>
