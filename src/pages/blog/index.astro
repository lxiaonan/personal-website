---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleList from '../../components/ArticleList.astro';
import { profile } from '../../data/site';

const articles = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tagCounts = articles
  .flatMap((article) => article.data.tags)
  .reduce<Record<string, number>>((acc, tag) => {
    acc[tag] = (acc[tag] ?? 0) + 1;
    return acc;
  }, {});

const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 12);

const tagKey = (tag: string) => tag.trim().toLowerCase();

const aiCount = articles.filter((article) =>
  article.data.tags.some((tag) => ['AI', 'Agent', 'MCP', 'RAG', 'Spring AI'].includes(tag))
).length;
---

<BaseLayout title="文章" description="围绕 Java 后端、广告投放、批量工作流、BI 分析和 AI Agent 工程化的实践文章。">
  <section class="section blog-section">
    <div class="container">
      <div class="blog-hero">
        <div>
          <p class="eyebrow">Backend Field Notes</p>
          <h1 class="section-title">从实际场景中记录的开发实践笔记。</h1>
          <p class="section-copy">
            围绕广告平台、批创流程、BI 查询链路和 AI Agent 接入，记录我在 Java 后端开发中遇到的真实问题、取舍和复盘。
          </p>
        </div>
      </div>

      <div class="blog-layout">
        <div class="blog-aside" aria-label="文章筛选">
          <div class="tag-panel">
            <button type="button" class="tag-filter active" data-tag-filter="all" aria-pressed="true">全部</button>
            {topTags.map(([tag, count]) => <button type="button" class="tag-filter" data-tag-filter={tagKey(tag)} aria-pressed="false">{tag}<em>{count}</em></button>)}
          </div>

          <div class="source-panel">
            <a href={profile.github}>GitHub</a>
            <a href={profile.csdn}>CSDN</a>
            <a href={profile.linuxdo}>Linux.do</a>
          </div>
        </div>

        <div class="blog-main">
          <div class="list-head">
            <span>{articles.length} articles / {Object.keys(tagCounts).length} topics / {aiCount} AI notes</span>
            <span data-visible-count>{articles.length} shown</span>
          </div>
          <ArticleList articles={articles} />
          <p class="empty-state" data-empty-state hidden>这个标签下暂时没有文章，换个方向看看。</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const articles = Array.from(document.querySelectorAll('[data-article-item]'));
  const tagButtons = Array.from(document.querySelectorAll('[data-tag-filter]'));
  const visibleCount = document.querySelector('[data-visible-count]');
  const emptyState = document.querySelector('[data-empty-state]');

  let activeTag = 'all';

  function updateArticleVisibility() {
    let count = 0;

    articles.forEach((item) => {
      if (!(item instanceof HTMLElement)) return;
      const tagMatch = activeTag === 'all' || (item.dataset.tags ?? '').split('|').includes(activeTag);
      const show = tagMatch;
      item.hidden = !show;
      if (show) count++;
    });

    if (visibleCount instanceof HTMLElement) visibleCount.textContent = `${count} shown`;
    if (emptyState instanceof HTMLElement) emptyState.hidden = count > 0;
  }

  tagButtons.forEach((button) => {
    button.addEventListener('click', () => {
      if (!(button instanceof HTMLElement)) return;
      activeTag = button.dataset.tagFilter ?? 'all';
      tagButtons.forEach((item) => {
        const selected = item === button;
        item.classList.toggle('active', selected);
        if (item instanceof HTMLElement) item.setAttribute('aria-pressed', String(selected));
      });
      updateArticleVisibility();
    });
  });
</script>

<style>
  .blog-section {
    padding-block-start: 64px;
  }

  .blog-hero {
    max-width: 820px;
    padding-bottom: 26px;
  }

  .list-head,
  .source-panel a {
    color: var(--faint);
    font-family: var(--mono);
    font-size: 0.74rem;
    font-style: normal;
    font-weight: 760;
    text-transform: uppercase;
  }

  .blog-layout {
    display: grid;
    gap: 18px;
    align-items: start;
    margin-top: 12px;
  }

  .blog-aside {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    border-block: 1px solid var(--line);
    padding-block: 14px;
  }

  .tag-panel,
  .source-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .tag-filter,
  .source-panel a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    gap: 7px;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 10px;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 0.84rem;
    font-weight: 720;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background 160ms ease;
  }

  .tag-filter:hover,
  .source-panel a:hover,
  .tag-filter.active {
    border-color: color-mix(in srgb, var(--accent), var(--line) 38%);
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .tag-filter em {
    color: inherit;
    font-family: var(--mono);
    font-size: 0.72rem;
    font-style: normal;
    opacity: 0.72;
  }

  .blog-main {
    min-width: 0;
    max-width: 940px;
  }

  .list-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 2px 6px;
  }

  .empty-state {
    padding: 22px 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .blog-aside {
      display: grid;
      gap: 16px;
    }
  }
</style>
